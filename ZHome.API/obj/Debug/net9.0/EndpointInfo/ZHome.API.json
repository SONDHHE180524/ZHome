  "components": {
    "schemas": {
      "CheckInRequestDto": {
        "required": [
          "endDate",
          "roomId",
          "roomPrice",
          "startDate",
          "tenantFullName",
          "tenantIdCardNumber",
          "tenantPhone"
        ],
        "type": "object",
        "properties": {
          "roomId": {
            "type": "integer",
            "format": "int64"
          },
          "tenantFullName": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "tenantPhone": {
            "minLength": 1,
            "pattern": "^0[35789]\\d{8}$",
            "type": "string"
          },
          "tenantIdCardNumber": {
            "minLength": 1,
            "pattern": "^(\\d{9}|\\d{12})$",
            "type": "string"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "roomPrice": {
            "minimum": 0,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "CreateSupplementaryBillDto": {
        "required": [
          "amount",
          "month",
          "roomId",
          "year"
        ],
        "type": "object",
        "properties": {
          "roomId": {
            "type": "integer",
            "format": "int64"
          },
          "month": {
            "type": "integer",
            "format": "int32"
          },
          "year": {
            "type": "integer",
            "format": "int32"
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "note": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "required": [
          "password",
          "phone"
        ],
        "type": "object",
        "properties": {
          "phone": {
